{
  "name": "NAV frontend",
  "description": "Network Administration Visualized frontend",
  "version": "5",
  "private": true,
  "devDependencies": {
    "sass": "^1.71.1"
  },
  "dependencies": {
    "backbone": "1.0.0",
    "backbone.marionette": "4.1.3",
    "backbone.radio": "2.0.0",
    "d3": "7.8.3",
    "datatables.net": "2.2.2",
    "flatpickr": "4.6.13",
    "htmx.org": "2.0.4",
    "jquery": "4.0.0",
    "moment": "2.18.1",
    "select2": "4.1.0-rc.0",
    "spin.js": "2.3.2",
    "tablesort": "5.7.0",
    "underscore": "1.7.0",
    "vue": "2.2.0"
  },
  "scripts": {
    "watch:sass": "cd python/nav/web && sass --quiet --watch sass/nav.scss:static/css/nav.css sass/nav/:static/css/nav/ sass/font-awesome/font-awesome.scss:static/css/font-awesome/font-awesome.css",
    "build:sass": "cd python/nav/web && sass --quiet --style=compressed --no-source-map sass/nav.scss:static/css/nav.css sass/nav/:static/css/nav/ sass/font-awesome/font-awesome.scss:static/css/font-awesome/font-awesome.css"
  }
}
